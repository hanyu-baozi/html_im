# 数据库配置
# 格式: mysql://用户名:密码@主机:端口/数据库名
DATABASE_URL=mysql://html_im_user:YOUR_STRONG_PASSWORD@localhost:3306/html_im

# Redis 配置
REDIS_URL=redis://127.0.0.1:6379

# JWT 配置
# 请生成一个强密钥：openssl rand -base64 64
JWT_SECRET=YOUR_STRONG_JWT_SECRET_KEY_HERE

# 服务器配置
# 生产环境请设置为 127.0.0.1，通过 Nginx 反向代理
# 开发环境可设置为 0.0.0.0
SERVER_HOST=127.0.0.1
SERVER_PORT=8080

# CORS 配置
# 允许的前端访问来源
ALLOWED_ORIGIN=http://localhost:3000

# 日志级别
# 可选值: error, warn, info, debug, trace
RUST_LOG=info
